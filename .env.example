# ── Server ──
PORT=3200
REFRESH_INTERVAL_MINUTES=15

# ── LLM Provider (optional — for AI-enhanced analysis) ──
# Providers: anthropic, openai, gemini, disabled
LLM_PROVIDER=disabled
LLM_API_KEY=
LLM_MODEL=

# ── Optional API Keys (enable additional sources) ──
# GitHub personal access token (higher rate limits)
GITHUB_TOKEN=
# NewsAPI key (https://newsapi.org — free tier)
NEWSAPI_KEY=
# Reddit (OAuth — https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
