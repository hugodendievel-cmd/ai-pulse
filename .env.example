# ── Server ──
PORT=3200
REFRESH_INTERVAL_MINUTES=15

# ── LLM Provider (optional — for AI-enhanced analysis) ──
# Providers: anthropic, openai, gemini, disabled
LLM_PROVIDER=disabled
LLM_API_KEY=
LLM_MODEL=

# ── Optional API Keys (enable additional sources) ──
# GitHub personal access token (higher rate limits)
GITHUB_TOKEN=
# NewsAPI key (https://newsapi.org — free tier)
NEWSAPI_KEY=
# Reddit (OAuth — https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Server limits ──
MAX_SSE_CLIENTS=200            # max concurrent SSE connections
MAX_LLM_CALLS_PER_DAY=100      # daily LLM budget — persisted across restarts (Europe/Brussels day boundary)

# ── Logging ──
LOG_LEVEL=info                 # pino log level: trace | debug | info | warn | error
NODE_ENV=                      # production | development — affects asset cache TTL and pino transport
